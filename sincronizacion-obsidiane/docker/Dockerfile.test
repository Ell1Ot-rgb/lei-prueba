# Dockerfile.test - Para Pruebas Rápidas del Sistema Hexagonal
# ============================================================

FROM python:3.11-slim

# Variables de entorno
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Instalar dependencias necesarias para compilar mmh3
RUN apt-get update && apt-get install -y \
    gcc \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Instalar solo las dependencias necesarias de ejecución del núcleo y adaptador Obsidian
RUN pip install --no-cache-dir \
    numpy==1.26.4 \
    PyYAML==6.0.1 \
    psutil==5.9.6 \
    mmh3==4.1.0 \
    Flask==3.0.0 \
    watchdog==3.0.0 \
    python-dotenv==1.0.0

# Copiar el código del sistema
COPY . .

# Exponer el puerto del webhook
EXPOSE 5679

# Comando por defecto para correr los tests de integración en el contenedor
CMD ["python", "tests/test_pipeline_evolucionado.py"]
